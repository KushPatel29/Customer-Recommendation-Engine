	partition sku_affinity = m
		mode: import
		source =
				let
				    // Basket-lift pairs from the market-basket analysis.
				    Source = Csv.Document(File.Contents(DataPath & "\output\sku_affinity.csv"), [Delimiter = ",", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]),
				    Promoted = Table.PromoteHeaders(Source, [PromoteAllScalars = true]),
				    Typed = Table.TransformColumnTypes(Promoted, {{"sku_a", type text}, {"description_a", type text}, {"sku_b", type text}, {"description_b", type text}, {"orders_together", Int64.Type}, {"confidence_a_to_b", type number}, {"lift", type number}})
				in
				    Typed
