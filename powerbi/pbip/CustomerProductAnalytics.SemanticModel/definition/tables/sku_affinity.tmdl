table sku_affinity
	lineageTag: fb4469ea-8b24-497e-90d9-992ecb70b80a

	column sku_a
		dataType: string
		lineageTag: fdaa40a5-094b-4e0f-8c02-9c5f823ae261
		summarizeBy: none
		sourceColumn: sku_a

	column description_a
		dataType: string
		lineageTag: 94cd7eef-cd09-4dc6-89cc-e75cee85a281
		summarizeBy: none
		sourceColumn: description_a

	column sku_b
		dataType: string
		lineageTag: 459e249d-99f9-4565-8245-2fe652c2bc68
		summarizeBy: none
		sourceColumn: sku_b

	column description_b
		dataType: string
		lineageTag: 1b485f63-61cc-4faa-a4ee-fd978a797b03
		summarizeBy: none
		sourceColumn: description_b

	column orders_together
		dataType: int64
		formatString: 0
		lineageTag: fd796005-a81e-4cb8-9baf-833977aed22f
		summarizeBy: sum
		sourceColumn: orders_together

	column confidence_a_to_b
		dataType: double
		formatString: 0.0%
