{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.0.0/schema.json",
  "name": "visual036",
  "position": {
    "x": 660,
    "y": 150,
    "z": 36000,
    "height": 280,
    "width": 600,
    "tabOrder": 36000
  },
  "visual": {
    "visualType": "columnChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "dim_customer"
                    }
                  },
                  "Property": "region"
                }
              },
              "queryRef": "dim_customer.region",
              "nativeQueryRef": "region"
            }
          ]
        },
        "Series": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "dim_product"
                    }
                  },
                  "Property": "protein"
                }
              },
              "queryRef": "dim_product.protein",
              "nativeQueryRef": "protein"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Total Revenue"
                }
              },
              "queryRef": "_Measures.Total Revenue",
              "nativeQueryRef": "Total Revenue"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true,
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Revenue by Region and Protein'"
                }
              }
            },
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ]
    }
  }
}
