{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.0.0/schema.json",
  "name": "visual016",
  "position": {
    "x": 20,
    "y": 150,
    "z": 16000,
    "height": 280,
    "width": 620,
    "tabOrder": 16000
  },
  "visual": {
    "visualType": "scatterChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "dim_product"
                    }
                  },
                  "Property": "description"
                }
              },
              "queryRef": "dim_product.description",
              "nativeQueryRef": "description"
            }
          ]
        },
        "Series": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "dim_product"
                    }
                  },
                  "Property": "abc_class"
                }
              },
              "queryRef": "dim_product.abc_class",
              "nativeQueryRef": "abc_class"
            }
          ]
        },
        "X": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Margin %"
                }
              },
              "queryRef": "_Measures.Margin %",
              "nativeQueryRef": "Margin %"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Total Revenue"
                }
              },
              "queryRef": "_Measures.Total Revenue",
              "nativeQueryRef": "Total Revenue"
            }
          ]
        }
      }
    },
    "drillFilterOtherVisuals": true,
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Portfolio: Margin % x Revenue by ABC Class'"
                }
              }
            },
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ]
    }
  }
}
